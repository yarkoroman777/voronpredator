# Binance API (без права вывода)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET=your_secret_key_here

# Telegram уведомления (опционально)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Настройки бота
MIN_SPREAD_PERCENT=0.35      # минимальный спред для сделки (в процентах)
SLIPPAGE_TOLERANCE=0.1       # допустимое проскальзывание (% от суммы)
INITIAL_CAPITAL=1000         # начальный капитал в USDT (для логов, не влияет на торговлю)
